# App
BMP2SVG_JWT_SECRET=change-this-secret-in-production
DATABASE_URL=postgresql://bmp2svg:bmp2svg@127.0.0.1:5432/bmp2svg
REDIS_URL=redis://127.0.0.1:6379/0
BMP2SVG_STATE_USE_REDIS=1
BMP2SVG_QUEUE_NAME=bmp2svg-jobs
BMP2SVG_JOB_MAX_RETRIES=2
BMP2SVG_ADMIN_TOKEN=change-this-admin-token
BMP2SVG_STUCK_JOB_SEC=600

# Ollama AI assistant
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava
OLLAMA_TIMEOUT_SEC=60

# Docker Postgres defaults used in docker-compose.yml
POSTGRES_DB=bmp2svg
POSTGRES_USER=bmp2svg
POSTGRES_PASSWORD=bmp2svg
